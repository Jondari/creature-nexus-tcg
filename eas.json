{
  "cli": {
    "version": ">= 16.17.4",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "e2e-test": {
      "withoutCredentials": true,
      "env": {
        "EXPO_PUBLIC_DEMO_MODE": "true"
      },
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal"            // generate APK
    },
    "preview-store": {
      "distribution": "store",              // important to target the store
      "android": { "buildType": "app-bundle" }, // AAB (not APK)
      "autoIncrement": true
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
